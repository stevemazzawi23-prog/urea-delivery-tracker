# ============================================================
# SP Logistix - Configuration des variables d'environnement
# ============================================================
# Copiez ce fichier en .env et remplissez les valeurs.
# Le fichier .env ne doit JAMAIS être commité sur GitHub.

# ── Base de données MySQL sur votre VPS ─────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=mysql://splogistix:VOTRE_MOT_DE_PASSE@localhost:3306/splogistix_db

# ── Sécurité JWT ────────────────────────────────────────────
# Clé secrète pour signer les tokens JWT (minimum 32 caractères)
JWT_SECRET=CHANGEZ_CETTE_CLE_SECRETE_MINIMUM_32_CHARS

# ── Identifiant de l'application ────────────────────────────
VITE_APP_ID=sp-logistix

# ── OAuth (optionnel si vous utilisez uniquement driver-login) ──
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# ── Port du serveur backend ──────────────────────────────────
PORT=3000

# ── URL publique de votre VPS (pour l'app mobile Android/iOS) ──
# Remplacez par l'IP ou le domaine de votre VPS
# Exemple: http://123.456.789.0:3000  ou  https://api.splogistix.com
EXPO_PUBLIC_API_BASE_URL=http://VOTRE_IP_VPS:3000

# ── Variables Expo (frontend mobile) ────────────────────────
EXPO_PUBLIC_APP_ID=sp-logistix
EXPO_PUBLIC_OWNER_OPEN_ID=
EXPO_PUBLIC_OWNER_NAME=
EXPO_PUBLIC_OAUTH_PORTAL_URL=
EXPO_PUBLIC_OAUTH_SERVER_URL=
